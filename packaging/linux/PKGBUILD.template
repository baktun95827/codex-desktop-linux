# Maintainer: Codex Desktop Linux Maintainers
pkgname=__PACKAGE_NAME__
pkgver=__PKGVER__
pkgrel=__PKGREL__
pkgdesc="Codex Desktop for Linux — community-built from the macOS DMG"
arch=('__ARCH__')
url="https://github.com/ilysenko/codex-desktop-linux"
license=('MIT')
depends=(
    'python'
    'p7zip'
    'polkit'
    'curl'
    'unzip'
    'gcc'
    'make'
    # Electron runtime libraries
    'alsa-lib'
    'at-spi2-core'
    'atk'
    'cairo'
    'dbus'
    'glib2'
    'gtk3'
    'libcups'
    'libdrm'
    'libx11'
    'libxcb'
    'libxcomposite'
    'libxdamage'
    'libxext'
    'libxfixes'
    'libxkbcommon'
    'libxrandr'
    'mesa'
    'nspr'
    'nss'
    'pango'
)
optdepends=(
    'zenity: GTK dialog fallback when the Codex CLI is missing'
    'kdialog: KDE dialog fallback when the Codex CLI is missing'
    'nodejs: Node.js 22.22+ for Browser Use and local rebuilds when no user-managed Node is available'
    'npm: install or update the Codex CLI and rebuild future packages'
)
options=(!debug !strip)
install=__PACKAGE_NAME__.install
source=()
sha256sums=()

package() {
    cp -a "__STAGING_DIR__/." "${pkgdir}/"
}
